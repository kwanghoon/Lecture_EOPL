source-repository head
  type: git
  location: https://github.com/githubuser/ch8

library
  exposed-modules:
      Lib
  other-modules:
      Paths_ch8
  hs-source-dirs:
      src
  build-depends:
      base >=4.7 && <5
    , containers
    , hspec
    , transformers
    , yapb >=0.2.3
  default-language: Haskell2010

executable opaquetypes-exe
  main-is: Main.hs
  other-modules:
      EitherState
      Env
      Expr
      Interp
      Lexer
      MainUtil
      Parser
      Testcase
      Token
      TyEnv
      TypeCheck
      Paths_ch8
  hs-source-dirs:
      app/opaquetypes
  ghc-options: -threaded -rtsopts -with-rtsopts=-N
  build-depends:
      base >=4.7 && <5
    , ch8
    , containers
    , hspec
    , transformers
    , yapb >=0.2.3
  default-language: Haskell2010

