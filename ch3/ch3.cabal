source-repository head
  type: git
  location: https://github.com/githubuser/ch3

library
  exposed-modules:
      Lib
  other-modules:
      Paths_ch3
  hs-source-dirs:
      src
  build-depends:
      base >=4.7 && <5
    , hspec
    , yapb >=0.2.3
  default-language: Haskell2010

